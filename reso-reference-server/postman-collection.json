{
  "info": {
    "name": "RESO Reference Server",
    "description": "Comprehensive API collection for the RESO Reference Server — an OData 4.0 compliant server implementing the RESO Data Dictionary.\n\nDefault tokens:\n- admin-token (admin role: full access)\n- write-token (write role: CRUD)\n- read-token (read role: queries only)\n\nSet {{base_url}} and {{auth_token}} in the collection variables or an environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "admin-token",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health & Service Info",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Returns server health status and metadata version."
          }
        },
        {
          "name": "OData Service Document",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "Returns the OData service document listing all available entity sets."
          }
        },
        {
          "name": "OData $metadata (EDMX XML)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/$metadata",
              "host": ["{{base_url}}"],
              "path": ["$metadata"]
            },
            "description": "Returns the EDMX XML metadata document describing all entity types, properties and enumerations."
          }
        },
        {
          "name": "OpenAPI Spec (JSON)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api-docs/spec.json",
              "host": ["{{base_url}}"],
              "path": ["api-docs", "spec.json"]
            },
            "description": "Returns the raw OpenAPI 3.0 specification in JSON format."
          }
        },
        {
          "name": "UI Config",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/ui-config",
              "host": ["{{base_url}}"],
              "path": ["ui-config"]
            },
            "description": "Returns summary field configuration used by the web UI."
          }
        },
        {
          "name": "Field Groups",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/field-groups",
              "host": ["{{base_url}}"],
              "path": ["field-groups"]
            },
            "description": "Returns RESO Data Dictionary field groupings used by the web UI."
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "OAuth2 Token (Client Credentials)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "client_credentials"
                },
                {
                  "key": "client_id",
                  "value": "my-client-id"
                },
                {
                  "key": "client_secret",
                  "value": "my-client-secret"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/oauth/token",
              "host": ["{{base_url}}"],
              "path": ["oauth", "token"]
            },
            "description": "Mock OAuth2 Client Credentials endpoint. Accepts any client_id/client_secret and returns a bearer token with 'write' role by default."
          }
        },
        {
          "name": "OAuth2 Token (Admin Role)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "client_credentials"
                },
                {
                  "key": "client_id",
                  "value": "my-client-id"
                },
                {
                  "key": "client_secret",
                  "value": "my-client-secret"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/oauth/token?role=admin",
              "host": ["{{base_url}}"],
              "path": ["oauth", "token"],
              "query": [
                {
                  "key": "role",
                  "value": "admin"
                }
              ]
            },
            "description": "Mock OAuth2 endpoint with ?role=admin to get an admin-level token. Roles: read, write, admin."
          }
        }
      ]
    },
