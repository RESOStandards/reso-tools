    {
      "name": "Property",
      "item": [
        {
          "name": "List Properties",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/Property",
              "host": ["{{base_url}}"],
              "path": ["Property"]
            },
            "description": "Returns the Property collection with default server paging."
          }
        },
        {
          "name": "List Properties — $top & $skip",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/Property?$top=5&$skip=0",
              "host": ["{{base_url}}"],
              "path": ["Property"],
              "query": [
                {
                  "key": "$top",
                  "value": "5"
                },
                {
                  "key": "$skip",
                  "value": "0"
                }
              ]
            },
            "description": "Paginate through properties: fetch 5 records starting at offset 0."
          }
        },
        {
          "name": "List Properties — $count",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/Property?$count=true&$top=0",
              "host": ["{{base_url}}"],
              "path": ["Property"],
              "query": [
                {
                  "key": "$count",
                  "value": "true"
                },
                {
                  "key": "$top",
                  "value": "0"
                }
              ]
            },
            "description": "Returns the total count of Property records without returning any records (top=0)."
          }
        },
        {
          "name": "List Properties — $select",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/Property?$select=ListingKey,ListPrice,StandardStatus,City,StateOrProvince&$top=10",
              "host": ["{{base_url}}"],
              "path": ["Property"],
              "query": [
                {
                  "key": "$select",
                  "value": "ListingKey,ListPrice,StandardStatus,City,StateOrProvince"
                },
                {
                  "key": "$top",
                  "value": "10"
                }
              ]
            },
            "description": "Select only specific fields to reduce payload size."
          }
        },
        {
          "name": "List Properties — $filter",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/Property?$filter=ListPrice gt 500000 and StandardStatus eq 'Active'&$top=10",
              "host": ["{{base_url}}"],
              "path": ["Property"],
              "query": [
                {
                  "key": "$filter",
                  "value": "ListPrice gt 500000 and StandardStatus eq 'Active'"
                },
                {
                  "key": "$top",
                  "value": "10"
                }
              ]
            },
            "description": "Filter properties with price above 500k and Active status."
          }
        },
        {
          "name": "List Properties — $orderby",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/Property?$orderby=ListPrice desc&$top=10",
              "host": ["{{base_url}}"],
              "path": ["Property"],
              "query": [
                {
                  "key": "$orderby",
                  "value": "ListPrice desc"
                },
                {
                  "key": "$top",
                  "value": "10"
                }
              ]
            },
            "description": "Sort properties by ListPrice in descending order."
          }
        },
        {
          "name": "List Properties — $expand Media",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/Property?$expand=Media&$top=5",
              "host": ["{{base_url}}"],
              "path": ["Property"],
              "query": [
                {
                  "key": "$expand",
                  "value": "Media"
                },
                {
                  "key": "$top",
                  "value": "5"
                }
              ]
            },
            "description": "Expand the Media navigation property to include associated media records inline."
          }
        },
        {
          "name": "List Properties — Combined Query",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/Property?$filter=ListPrice gt 200000&$select=ListingKey,ListPrice,City,StandardStatus&$orderby=ModificationTimestamp desc&$top=10&$count=true",
              "host": ["{{base_url}}"],
              "path": ["Property"],
              "query": [
                {
                  "key": "$filter",
                  "value": "ListPrice gt 200000"
                },
                {
                  "key": "$select",
                  "value": "ListingKey,ListPrice,City,StandardStatus"
                },
                {
                  "key": "$orderby",
                  "value": "ModificationTimestamp desc"
                },
                {
                  "key": "$top",
                  "value": "10"
                },
                {
                  "key": "$count",
                  "value": "true"
                }
              ]
            },
            "description": "Combined query: filter + select + orderby + top + count."
          }
        },
        {
          "name": "Get Property by Key",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/Property('{{listing_key}}')",
              "host": ["{{base_url}}"],
              "path": ["Property('{{listing_key}}')"]
            },
            "description": "Retrieve a single Property by its ListingKey. Replace {{listing_key}} with an actual key."
          }
        },
        {
          "name": "Create Property",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ListPrice\": 450000,\n  \"StandardStatus\": \"Active\",\n  \"PropertyType\": \"Residential\",\n  \"City\": \"Austin\",\n  \"StateOrProvince\": \"TX\",\n  \"PostalCode\": \"78701\",\n  \"StreetName\": \"Main St\",\n  \"StreetNumber\": \"123\",\n  \"BedroomsTotal\": 3,\n  \"BathroomsTotalInteger\": 2,\n  \"LivingArea\": 1800\n}"
            },
            "url": {
              "raw": "{{base_url}}/Property",
              "host": ["{{base_url}}"],
              "path": ["Property"]
            },
            "description": "Create a new Property record. The server will assign a ListingKey and ModificationTimestamp."
          }
        },
        {
          "name": "Update Property",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ListPrice\": 475000,\n  \"StandardStatus\": \"Pending\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/Property('{{listing_key}}')",
              "host": ["{{base_url}}"],
              "path": ["Property('{{listing_key}}')"]
            },
            "description": "Update an existing Property. Only the supplied fields are changed (PATCH merge semantics)."
          }
        },
        {
          "name": "Delete Property",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/Property('{{listing_key}}')",
              "host": ["{{base_url}}"],
              "path": ["Property('{{listing_key}}')"]
            },
            "description": "Delete a Property by its ListingKey."
          }
        }
      ]
    },
